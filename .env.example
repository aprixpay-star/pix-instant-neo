# ============================================================================
# FRONTEND (exposed to the browser via VITE_* prefix)
# Configure these in the Vercel Dashboard under Settings > Environment Variables.
# ============================================================================

# Supabase Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Publishable Key (Anon Key) - safe to expose in the browser
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here

# Mercado Pago Public Key - safe to expose in the browser (used by the MP SDK)
VITE_MERCADOPAGO_PUBLIC_KEY=your_public_key_here

# ============================================================================
# BACKEND / SERVER (read via process.env in server functions, webhook, auth middleware)
# Configure these in the Vercel Dashboard under Settings > Environment Variables.
# NEVER prefix these with VITE_ — they must stay server-side only.
# ============================================================================

# Supabase Project URL (server-side)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Publishable Key (Anon Key) - used by the server-side auth middleware
SUPABASE_PUBLISHABLE_KEY=your_anon_key_here

# Supabase Service Role Key - bypasses RLS. NEVER expose in the browser.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Mercado Pago Access Token - used by server functions and the webhook
MERCADOPAGO_ACCESS_TOKEN=your_access_token_here

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================
NODE_ENV=development
