# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
# Get these values from: https://app.supabase.com/project/YOUR_PROJECT_ID/settings/api

# Supabase Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Publishable Key (Anon Key) - Safe to expose in frontend
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here

# Supabase Service Role Key - NEVER expose in frontend, backend only
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================================================
# MERCADO PAGO CONFIGURATION (if needed)
# ============================================================================
# Get these from: https://www.mercadopago.com.br/developers/panel/app

# VITE_MERCADO_PAGO_PUBLIC_KEY=your_public_key_here

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================
NODE_ENV=development
